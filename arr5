import java.util.Scanner;
import java.util.Arrays;
import java.util.Random;

public class Main {
    public static void main(String[] args) {
        Random r = new Random();
        double avg1 = 0;
        double avg2 = 0;
        double[] array1 = new double[4];
        double[] array2 = new double[4];
        for (int i = 1; i < array1.length; i++) {
            array1[i] = r.nextInt(6);
            avg1+=array1[i] / array1.length;
        }
        for (int i = 1; i < array2.length; i++) {
            array2[i] = r.nextInt(6);
            avg2+=array2[i]/ array2.length;
        }
        System.out.println("Массив №1: " + Arrays.toString(array1));
        System.out.println("Массив №2: " + Arrays.toString(array2));
        System.out.println("Среднее арифметическое для массива №1: " + avg1);
        System.out.println("Среднее арифметическое для массива №2: " + avg2);
        if (avg1<avg2)
        {
            System.out.println("Среднее арифметическое больше для массива №2.");
        }
        if (avg1>avg2)
        {
            System.out.println("Среднее арифметическое больше для массива №1.");
        }
        if (avg1==avg2)
        {
            System.out.println("Средние арифметические массива №1 и массива №2 равна." );
        }
    }
}
